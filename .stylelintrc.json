{
  "extends": ["stylelint-config-tailwindcss"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "custom-variant",
          "theme",
          "layer",
          "apply",
          "tailwind",
          "responsive",
          "screen"
        ]
      }
    ]
  }
}
